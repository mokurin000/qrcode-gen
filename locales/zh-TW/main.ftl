-version = 版本
-error = 錯誤
-ec-level = 糾錯等級
-qr-code = 二維碼

version-normal = { -version }: { $v }, { -ec-level }: { $ec_level }
version-micro-simple = { -version }: M{ $v }
version-micro = { -version }: M{ $v }, { -ec-level }: { $ec_level }
error-ec-level-not-supported = { -error }: EC 等級 { $ec_level } 在 M{ $v } 中不受支援
error-data-too-long = { -error }: 資料過長
error-unsupported-charset = { -error }: 不支援的字元集
error-unknown = { -error }: 未知錯誤
