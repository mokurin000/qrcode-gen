version-micro = { -version }: M{ $v }, { -ec-level }: { $ec_level }
error-ec-level-not-supported = { -error }: { -ec-level } { $ec_level } не поддерживается в M{ $v }
error-data-too-long = { -error }: данные слишком длинные
error-unsupported-charset = { -error }: неподдерживаемая кодировка
error-unknown = { -error }: неизвестная ошибка
