-version = גרסה
-error = שגיאה
-ec-level = רמת EC
-qr-code = קוד QR

version-normal = { -version }: { $v }, { -ec-level }: { $ec_level }
version-micro-simple = { -version }: M{ $v }
version-micro = { -version }: M{ $v }, { -ec-level }: { $ec_level }
error-ec-level-not-supported = { -error }: { -ec-level } { $ec_level } אינו נתמך ב-M{ $v }
error-data-too-long = { -error }: הנתונים ארוכים מדי
error-unsupported-charset = { -error }: ערכת תווים שאינה נתמכת
error-unknown = { -error }: שגיאה לא ידועה
