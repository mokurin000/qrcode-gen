-version = संस्करण
-error = त्रुटि
-ec-level = EC स्तर
-qr-code = क्यूआर कोड

version-normal = { -version }: { $v }, { -ec-level }: { $ec_level }
version-micro-simple = { -version }: M{ $v }
version-micro = { -version }: M{ $v }, { -ec-level }: { $ec_level }
error-ec-level-not-supported = { -error }: { -ec-level } { $ec_level } M{ $v } में समर्थित नहीं है
error-data-too-long = { -error }: डेटा बहुत लंबा है
error-unsupported-charset = { -error }: असमर्थित वर्ण सेट
error-unknown = { -error }: अज्ञात त्रुटि
